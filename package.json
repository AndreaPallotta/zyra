{
  "name": "zyra-compiler",
  "version": "0.1.0",
  "description": "Zyra language compiler (source .zy → ESM .js)",
  "main": "dist/cmd/zyra.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx cmd/zyra.ts",
    "start": "node dist/cmd/zyra.js",
    "test": "tsx test/run-all.ts",
    "coverage": "c8 --reporter=text --reporter=lcov npm test",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run build"
  },
  "keywords": ["zyra","compiler","language"],
  "author": "Andrea Pallotta",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AndreaPallotta/zyra.git"
  },
  "bugs": {
    "url": "https://github.com/AndreaPallotta/zyra/issues"
  },
  "icon": "assets/zyra-128x128.png",
  "homepage": "https://github.com/AndreaPallotta/zyra#readme",
  "type": "module",
  "files": [
    "dist"
  ],
  "types": "dist/index.d.ts",
  "bin": {
    "zyra": "dist/cmd/zyra.js"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "c8": "^10.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "uvu": "^0.5.6"
  }
}
